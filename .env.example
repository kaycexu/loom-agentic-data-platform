# Loom — 真实 LLM 配置（可选）
# 复制为 .env（已 gitignore）后填值即可；真实环境变量始终优先于 .env。
# 注意：mock 主链路 `loom demo` / `loom eval-verifier` 不需要任何 key 就能验证全部论点。
# 配好后先 `loom check-llm` 验证连通性，再 `loom run --policy llm --limit 1`。

# 任意 OpenAI 兼容接口（vLLM / LiteLLM / DeepSeek / 公司自建代理 / OpenAI 官方）
LOOM_LLM_API_KEY=your-token-here
LOOM_LLM_BASE_URL=https://your-proxy.example.com/v1
LOOM_LLM_MODEL=your-model-id

# 可选
# LOOM_LLM_TIMEOUT=60
